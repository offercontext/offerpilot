{
    "env": {
        "ENABLE_TOOL_SEARCH": "false"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-doc-check.sh"
                    }
